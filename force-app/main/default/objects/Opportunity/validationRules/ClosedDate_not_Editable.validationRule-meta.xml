<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ClosedDate_not_Editable</fullName>
    <active>true</active>
    <description>Closed Date cannot be changed from ui except for sys admin.</description>
    <errorConditionFormula>AND($Profile.Name &lt;&gt; &apos;System Administrator&apos;,
NOT(OR(ISPICKVAL(Status__c, &quot;Open&quot;))),
ISCHANGED(CloseDate)
)</errorConditionFormula>
    <errorMessage>Do Not Have Enough Access!</errorMessage>
</ValidationRule>
